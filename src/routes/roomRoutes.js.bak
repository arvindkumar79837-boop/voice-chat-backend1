const express = require('express');
const router = express.Router();
const roomProductionController = require('../controllers/room.production.controller');
const powerMatrixController = require('../controllers/powerMatrixController');
const authMiddleware = require('../middlewares/auth.middleware');
const { checkPowerMiddleware, checkRoomOwner } = require('../middlewares/powerValidation.middleware');
const { verifyStaff } = require('../middlewares/adminMiddleware');

router.use(authMiddleware);

// ===========================================================================
// ROOM MANAGEMENT
// ===========================================================================

// POST /api/rooms/create
router.post('/create', roomProductionController.createRoom);

// GET /api/rooms/live
router.get('/live', roomProductionController.getLiveRooms);

// GET /api/rooms/type/:roomType
router.get('/type/:roomType', roomProductionController.getRoomsByType);

// GET /api/rooms/:roomId
router.get('/:roomId', roomProductionController.getRoomDetail);

// POST /api/rooms/:roomId/join
router.post('/:roomId/join', roomProductionController.joinRoom);

// POST /api/rooms/:roomId/verify-password
router.post('/:roomId/verify-password', roomProductionController.verifyPassword);

// ===========================================================================
// SEAT MANAGEMENT
// ===========================================================================

// POST /api/rooms/:roomId/seats/:seatIndex/lock
router.post('/:roomId/seats/:seatIndex/lock', checkRoomOwner, roomProductionController.toggleSeatLock);

// POST /api/rooms/:roomId/seats/:seatIndex/mute
router.post('/:roomId/seats/:seatIndex/mute', [checkRoomOwner, checkPowerMiddleware], roomProductionController.toggleSeatMute);

// POST /api/rooms/:roomId/seats/:seatIndex/claim
router.post('/:roomId/seats/:seatIndex/claim', roomProductionController.claimSeat);

// POST /api/rooms/:roomId/seats/:seatIndex/release
router.post('/:roomId/seats/:seatIndex/release', roomProductionController.releaseSeat);

// POST /api/rooms/:roomId/seats/:seatIndex/kick
router.post('/:roomId/seats/:seatIndex/kick', [checkRoomOwner, checkPowerMiddleware], roomProductionController.kickFromSeat);

// ===========================================================================
// ROOM COSMETICS
// ===========================================================================

// PUT /api/rooms/:roomId/cosmetics
router.put('/:roomId/cosmetics', checkRoomOwner, roomProductionController.updateCosmetics);

// POST /api/rooms/:roomId/cosmetics/purchase-background
router.post('/:roomId/cosmetics/purchase-background', checkRoomOwner, roomProductionController.purchaseBackground);

// ===========================================================================
// ROOM RANKING
// ===========================================================================

// GET /api/rooms/ranking
router.get('/ranking', roomProductionController.getRoomRanking);

// POST /api/rooms/:roomId/gift
router.post('/:roomId/gift', roomProductionController.sendGiftToRoom);

// ===========================================================================
// ROOM PK BATTLES
// ===========================================================================

// POST /api/rooms/:roomId/pk/challenge
router.post('/:roomId/pk/challenge', roomProductionController.challengeRoomPK);

// GET /api/rooms/:roomId/pk/status
router.get('/:roomId/pk/status', roomProductionController.getPKStatus);

// ===========================================================================
// ROOM TASKS
// ===========================================================================

// GET /api/rooms/:roomId/tasks
router.get('/:roomId/tasks', roomProductionController.getRoomTasks);

// PUT /api/rooms/:roomId/tasks/:taskId/progress
router.put('/:roomId/tasks/:taskId/progress', roomProductionController.updateTaskProgress);

// POST /api/rooms/:roomId/tasks/:taskId/claim
router.post('/:roomId/tasks/:taskId/claim', roomProductionController.claimTaskReward);

// ===========================================================================
// POWER MATRIX
// ===========================================================================

// GET /api/rooms/power-matrix
router.get('/power-matrix', authMiddleware, verifyStaff, powerMatrixController.getPowerMatrix);

// PUT /api/rooms/power-matrix
router.put('/power-matrix', authMiddleware, verifyStaff, powerMatrixController.updatePowerMatrix);

// POST /api/rooms/power-matrix/reset
router.post('/power-matrix/reset', authMiddleware, verifyStaff, powerMatrixController.resetPowerMatrix);

// POST /api/rooms/check-power
router.post('/check-power', authMiddleware, checkPowerMiddleware, powerMatrixController.checkUserPower);

// GET /api/rooms/power-matrix/history
router.get('/power-matrix/history', authMiddleware, verifyStaff, powerMatrixController.getPowerMatrixHistory);

module.exports = router;