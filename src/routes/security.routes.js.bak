const express = require('express');
const router = express.Router();
const SecurityController = require('../controllers/security.controller');
const authMiddleware = require('../middlewares/auth.middleware');
const { requireRole } = require('../middlewares/auth.middleware');

// All security routes require authentication + owner/admin role.
const secureRole = [authMiddleware, requireRole('owner', 'admin', 'superAdminUid', 'ownerWeb')];

// ─── DASHBOARD ───────────────────────────────────────────────────────────────
router.get('/dashboard', ...secureRole, SecurityController.getDashboard);

// ─── FRAUD ALERTS ─────────────────────────────────────────────────────────────
router.get('/fraud-alerts', ...secureRole, SecurityController.getFraudAlerts);
router.put('/fraud-alerts/:id', ...secureRole, SecurityController.updateFraudAlert);

// ─── BANNED DEVICES ───────────────────────────────────────────────────────────
router.get('/banned-devices', ...secureRole, SecurityController.getBannedDevices);
router.post('/banned-devices', ...secureRole, SecurityController.banDevice);
router.delete('/banned-devices/:id', ...secureRole, SecurityController.unbanDevice);

// ─── BLOCKED IP ADDRESSES ─────────────────────────────────────────────────────
router.get('/blocked-ips', ...secureRole, SecurityController.getBlockedIps);
router.post('/blocked-ips', ...secureRole, SecurityController.blockIp);
router.delete('/blocked-ips/:id', ...secureRole, SecurityController.unblockIp);

// ─── AUDIT LOGS (immutable append-only) ───────────────────────────────────────
router.get('/audit-logs', ...secureRole, SecurityController.getAuditLogs);

// ─── LIVE THREATS ─────────────────────────────────────────────────────────────
router.get('/live-threats', ...secureRole, SecurityController.getLiveThreats);

module.exports = router;