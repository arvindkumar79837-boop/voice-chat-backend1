# ═══════════════════════════════════════════════════════════════════════════
# ARVIND PARTY BACKEND — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════

# ─── MANDATORY ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/arvind_party
JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# ─── FIREBASE (MANDATORY) ────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"arvind-6d29e",...}
FIREBASE_DATABASE_URL=https://arvind-6d29e-default-rtdb.firebaseio.com

# ─── RAZORPAY (MANDATORY for payments) ───────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── GOOGLE PLAY (MANDATORY for IAP verification) ────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=com.arvindparty.app
GOOGLE_PLAY_SERVICE_ACCOUNT=service-account@project.iam.gserviceaccount.com
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# ─── LIVEKIT (MANDATORY for voice rooms) ─────────────────────────────────
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WS_URL=wss://your-livekit-server.com

# ─── REDIS ───────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://127.0.0.1:6379

# ─── OPTIONAL: AWS / CDN ─────────────────────────────────────────────────
# Skip if not using AWS infrastructure
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_AUTOSCALING_GROUP=
AWS_LAMBDA_FUNCTION_NAME=
CLOUD_FRONT_DISTRIBUTION_ID=
CLOUD_FRONT_DOMAIN=

# ─── OPTIONAL: CDN Provider ──────────────────────────────────────────────
CDN_ENABLED=false
CDN_PROVIDER=cloudinary
CDN_IMAGES_DOMAIN=
CDN_STATIC_DOMAIN=
CDN_VIDEOS_DOMAIN=
CDN_CACHE_TTL=86400

# ─── OPTIONAL: Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── OPTIONAL: Agora (Voice Chat) ───────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ─── OPTIONAL: SMTP (Email) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=
ALERT_EMAIL_ENABLED=false

# ─── OPTIONAL: Sentry (Error Tracking) ───────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── OPTIONAL: OpenAI (AI Features) ──────────────────────────────────────
OPENAI_API_KEY=
AI_ERROR_RESOLUTION=

# ─── OPTIONAL: Backup ────────────────────────────────────────────────────
BACKUP_ENABLED=false
BACKUP_DIR=./backups
BACKUP_COMPRESSION=gzip
BACKUP_INTERVAL_MINUTES=60
BACKUP_RETENTION_DAYS=30
BACKUP_SERVER_MODE=local
BACKUP_SYNC_TOKEN=
MAX_BACKUPS=10

# ─── OPTIONAL: Auto-scaling ──────────────────────────────────────────────
AUTO_SCALING_ENABLED=false
ENABLE_AUTOSCALING=false
MIN_INSTANCES=1
MAX_INSTANCES=5
CPU_SCALE_THRESHOLD=80
MEMORY_SCALE_THRESHOLD=85
SCALE_COOLDOWN_MS=300000
HEALTH_ALERTS_ENABLED=false
HEALTH_CHECK_URL=/health
HEALTH_CHECK_INTERVAL=30000

# ─── OPTIONAL: Deploy ────────────────────────────────────────────────────
DEPLOY_BRANCH=main
DEPLOY_PATH=/var/www/arvind-party
DEPLOY_WEBHOOK_SECRET=
DEPLOY_DELAY_MS=5000
AUTO_DEPLOY_ENABLED=false
RENDER_SERVICE_ID=

# ─── OPTIONAL: Docker ────────────────────────────────────────────────────
DOCKER_CONTAINER_NAME=arvind-party-backend
DOCKER_SWARM_MODE=false

# ─── OPTIONAL: YouTube ───────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ─── OPTIONAL: Alerting ──────────────────────────────────────────────────
ALERT_SLACK_WEBHOOK=
ALERT_COOLDOWN_MS=300000

# ─── OPTIONAL: Audit ─────────────────────────────────────────────────────
AUDIT_LOGGING_ENABLED=true
AUDIT_BUFFER_SIZE=100
AUDIT_FLUSH_INTERVAL=30000
AUDIT_RETENTION_DAYS=90

# ─── OPTIONAL: Feature Flags ─────────────────────────────────────────────
FEATURE_FLAGS_ENABLED=false
FEATURE_FLAG_TTL=3600

# ─── OPTIONAL: Logging ───────────────────────────────────────────────────
DEBUG_LOGS=false
API_LOGS=true
HTTP_LOGS=true
DB_LOGS=false
LOG_TO_FILE=false

# ─── OPTIONAL: App Metadata ──────────────────────────────────────────────
APP_BASE_URL=http://localhost:5000
PRIMARY_SERVER_URL=http://localhost:5000
SERVER_ID=server-1
VERSION=1.0.0

# ─── OPTIONAL: MongoDB Auth ──────────────────────────────────────────────
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

# ─── OPTIONAL: PM2 ───────────────────────────────────────────────────────
PM=1
