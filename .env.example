# ═══════════════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT VARIABLES (.env.example)
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your local configuration.
# This .env file should be added to .gitignore and NEVER be committed.

# --- Core App Config ---
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/arvind_party
JWT_SECRET=YOUR_SUPER_SECRET_RANDOM_STRING_HERE_CHANGE_ME
REFRESH_TOKEN_SECRET=YOUR_ANOTHER_SUPER_SECRET_RANDOM_STRING_HERE_CHANGE_ME
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com

# --- Firebase Admin SDK Config ---
# Used for server-side operations like verifying ID tokens, sending FCM messages, etc.
# Get these values from your Firebase project's service account JSON file.
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@YOUR_PROJECT_ID.iam.gserviceaccount.com
# For the private key, you must replace all newline characters `
` with the literal characters `
` 
# to store it correctly as a single line in the .env file.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_CONTENT_HERE
-----END PRIVATE KEY-----
"
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID.firebaseio.com

# --- LiveKit Config ---
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET
LIVEKIT_WS_URL=wss://YOUR_LIVEKIT_DOMAIN

# --- Redis Config ---
# Optional: Railway managed Redis URL (preferred). Example:
# REDIS_URL=redis://red-xxxx:6379
# Fallback legacy fields (used only if REDIS_URL is not set):
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
