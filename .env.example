# ═══════════════════════════════════════════════════════════════════════════
# ARVIND PARTY BACKEND - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ─── SERVER ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://arvindkumar79837_db_user:

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_min_32_chars

# ─── REDIS ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=

# ─── TWILIO ──────────────────────────────────────────────────────────────
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── RAZORPAY ────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── FIREBASE ────────────────────────────────────────────────────────────
FIREBASE_ADMIN_SDK_PATH=./firebase-admin-sdk.json

# ─── FRONTEND URLS ───────────────────────────────────────────────────────
WEB_PANEL_URL=http://localhost:3000
MOBILE_APP_URL=http://localhost:8080

# ─── CORS ────────────────────────────────────────────────────────────────
CORS_ORIGIN=*