# ═══════════════════════════════════════════════════════════════════════════
# ARVIND PARTY - BACKEND ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS: Copy this file to .env, then fill in your values.
# DO NOT commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT SECURITY ─────────────────────────────────────────────────────────────
# INSERT YOUR JWT SECRET HERE - Use a strong random string (e.g., openssl rand -hex 64)
JWT_SECRET=YOUR_JWT_SECRET_HERE_CHANGE_ME

# ─── MONGODB ──────────────────────────────────────────────────────────────────
# INSERT YOUR MONGODB URI HERE (local or Atlas)
# Local: mongodb://127.0.0.1:27017/arvind_party
# Atlas: mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/arvind_party
MONGO_URI=mongodb://127.0.0.1:27017/arvind_party

# ─── REDIS ────────────────────────────────────────────────────────────────────
# INSERT YOUR REDIS URL HERE (optional - falls back to in-memory)
# Format: redis://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ─── FIREBASE ADMIN SDK ───────────────────────────────────────────────────────
# INSERT YOUR FIREBASE SERVICE ACCOUNT KEY HERE (JSON string or path to key file)
# Create a service account in Firebase Console > Project Settings > Service Accounts
# Then generate a new private key and paste the JSON contents here (single line)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json

# ─── SMS / OTP PROVIDER ───────────────────────────────────────────────────────
# INSERT YOUR SMS API KEY HERE (Twilio / MSG91 / AWS SNS)
# Used for phone OTP verification
SMS_API_KEY=YOUR_SMS_API_KEY_HERE
SMS_SENDER_ID=ARVNDP

# ─── RAZORPAY (Payments) ──────────────────────────────────────────────────────
# INSERT YOUR RAZORPAY KEYS HERE (from Razorpay Dashboard)
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET_HERE

# ─── AGORA (Live Streaming) ────────────────────────────────────────────────────
# INSERT YOUR AGORA APP ID HERE (from Agora Console)
AGORA_APP_ID=YOUR_AGORA_APP_ID_HERE
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE_HERE

# ─── ADMIN CREDENTIALS (First Run Setup) ──────────────────────────────────────
# INSERT YOUR OWNER UID HERE (from Firebase Auth)
OWNER_UID=YOUR_FIREBASE_UID_HERE
OWNER_LOGIN_ID=owner@arvindparty.com
OWNER_PASSWORD=YOUR_STRONG_OWNER_PASSWORD_HERE

# ─── CORS ORIGINS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Web Panel: http://localhost:3000 or https://admin.arvindparty.com
# Mobile App: Capacitor/WebView origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://192.168.1.100:3000

# ─── FEATURE FLAGS ────────────────────────────────────────────────────────────
ENABLE_COIN_MINTING=true
ENABLE_50_SPLIT=true
ENABLE_REWARD_INJECTOR=true