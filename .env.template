# ═══════════════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT VARIABLES (.env.template)
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your local configuration.
# This .env file should be added to .gitignore and NEVER be committed.

# --- Core App Config ---
PORT=5000
MONGO_URI=mongodb://localhost:27017/arvind_party
JWT_SECRET=YOUR_SUPER_SECRET_RANDOM_STRING_HERE_CHANGE_ME

# --- Firebase Admin SDK Config ---
# Used for server-side operations like verifying ID tokens from clients.
# Get these values from your Firebase project's service account JSON file.
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@YOUR_PROJECT_ID.iam.gserviceaccount.com
# For the private key, you must replace all newline characters `
` with the literal characters `
` 
# to store it correctly as a single line in the .env file.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_CONTENT_HERE
-----END PRIVATE KEY-----
"
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID.firebaseio.com
